# Use localhost when running the API locally.
# Use the Docker Compose service name when running the API in Docker.
POSTGRES_USER=urbangreen
POSTGRES_PASSWORD=
POSTGRES_DB=urbangreen_db
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_SCHEMA=

# Authentication / JWT
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Superuser (seeded on application startup)
SUPERUSER_EMAIL=admin@test.com
SUPERUSER_PASSWORD=
SUPERUSER_FULL_NAME=Administrator